{
  "name": "unocss-preset-prime",
  "type": "module",
  "version": "7.1.0",
  "description": "UnoCSS preset for supporting Prime UI theme colors and icons",
  "author": "Daniel Waltz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielwaltz/unocss-preset-prime.git"
  },
  "keywords": [
    "unocss",
    "unocss-preset",
    "prime"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./theme": "./dist/theme.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "playground:dev": "vite --config ./playground/vite.config.ts",
    "prepack": "npm run build",
    "release": "standard-version",
    "semantic-release": "semantic-release",
    "test": "npm run prepack && npm run lint && npm run type-check && npm run test:publish",
    "test:attw": "npx -y @arethetypeswrong/cli@latest --pack --profile esm-only",
    "test:publint": "npx -y publint@latest",
    "test:publish": "npm run test:attw && npm run test:publint",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@iconify-json/prime": ">=1.1.5",
    "unocss": ">=66.0.0 < 100"
  },
  "peerDependenciesMeta": {
    "@iconify-json/prime": {
      "optional": true
    }
  },
  "devDependencies": {
    "@danielwaltz/eslint-config": "^3.3.2",
    "@iconify-json/prime": "^1.2.4",
    "@primeuix/themes": "^2.0.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "~24.10.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@unocss/eslint-plugin": "^66.6.6",
    "@unocss/preset-wind4": "^66.6.6",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.0.3",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "primereact": "^11.0.0-alpha.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "semantic-release": "^25.0.3",
    "standard-version": "^9.5.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "unocss": "^66.6.6",
    "vite": "^7.3.1"
  },
  "overrides": {
    "conventional-changelog-conventionalcommits": ">=9.3.0"
  }
}
